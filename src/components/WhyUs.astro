---
import Reveal from "./Reveal";
import { differentiators } from "../data/content";
---

<section class="border-b border-ink-border py-24 sm:py-32">
  <div class="mx-auto grid max-w-6xl gap-12 px-5 sm:px-8 lg:grid-cols-[1fr_1.2fr]">
    <div class="lg:sticky lg:top-32 lg:self-start">
      <Reveal client:visible>
        <span class="text-xs uppercase tracking-[0.15em] text-gold-300">Why us</span>
        <h2 class="mt-4 text-balance font-display text-4xl leading-tight text-cream sm:text-5xl">
          Not another agency. Not another freelancer roulette.
        </h2>
        <p class="mt-6 max-w-md text-dusk-100/70">
          Lean by design. That means no bloated overhead, no junior devs learning on
          your dime, and no five-person meetings just to get a button moved.
        </p>
      </Reveal>
    </div>
    <div class="flex flex-col gap-6">
      {
        differentiators.map((d, i) => (
          <Reveal client:visible delay={i * 0.08} className="rounded-2xl border border-ink-border bg-ink-2/40 p-7">
            <h3 class="font-display text-xl text-gold-200">{d.title}</h3>
            <p class="mt-3 text-dusk-100/70">{d.description}</p>
          </Reveal>
        ))
      }
    </div>
  </div>
</section>
