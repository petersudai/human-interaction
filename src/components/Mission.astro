---
import Reveal from "./Reveal";
import { mission } from "../data/content";
---

<section class="border-b border-ink-border py-24 sm:py-32">
  <div class="mx-auto max-w-5xl px-5 sm:px-8">
    <Reveal client:visible className="text-center">
      <span class="text-xs uppercase tracking-[0.15em] text-gold-300">{mission.eyebrow}</span>
    </Reveal>

    <div class="mx-auto mt-10 grid max-w-3xl gap-10 text-center sm:grid-cols-2 sm:gap-12">
      <Reveal client:visible delay={0.1} className="text-center">
        <span class="text-xs uppercase tracking-[0.15em] text-dusk-100/50">Mission</span>
        <p class="mt-3 text-balance font-display text-3xl italic leading-snug text-cream sm:text-4xl">
          {mission.mission}
        </p>
      </Reveal>
      <Reveal client:visible delay={0.2} className="text-center">
        <span class="text-xs uppercase tracking-[0.15em] text-dusk-100/50">Vision</span>
        <p class="mt-3 text-balance font-display text-3xl italic leading-snug text-cream sm:text-4xl">
          {mission.vision}
        </p>
      </Reveal>
    </div>

    <Reveal client:visible delay={0.3} className="mx-auto mt-14 max-w-2xl text-center">
      <p class="text-dusk-100/70">{mission.note}</p>
    </Reveal>
  </div>
</section>
