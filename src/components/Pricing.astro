---
import Reveal from "./Reveal";
import { contact, guarantee, pricingTiers } from "../data/content";
---

<section id="pricing" class="border-b border-ink-border py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <Reveal client:visible className="mx-auto max-w-2xl text-center">
      <span class="text-xs uppercase tracking-[0.15em] text-gold-300">Investment</span>
      <h2 class="mt-4 text-balance font-display text-4xl leading-tight text-cream sm:text-5xl">
        Straightforward pricing. No surprise invoices.
      </h2>
      <p class="mt-5 text-dusk-100/70">
        Every project starts with a call to scope your exact needs. These are typical starting points.
      </p>
    </Reveal>

    <div class="mt-16 grid gap-6 lg:grid-cols-3 lg:items-center">
      {
        pricingTiers.map((t, i) => (
          <Reveal
            client:visible
            delay={i * 0.1}
            className={`relative rounded-3xl border p-8 ${
              t.highlighted
                ? "border-gold-400/60 bg-gradient-to-b from-gold-900/25 to-ink-2 shadow-glow-gold lg:scale-105 lg:py-10"
                : "border-ink-border bg-ink-2/40"
            }`}
          >
            {t.highlighted && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-gold-500 px-4 py-1 text-xs font-semibold text-ink">
                Most popular
              </span>
            )}
            <h3 class="font-display text-2xl text-cream">{t.name}</h3>
            <p class="mt-2 font-display text-3xl text-gold-200">{t.price}</p>
            <p class="mt-4 text-sm text-dusk-100/70">{t.description}</p>
            <ul class="mt-6 flex flex-col gap-3">
              {t.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-dusk-100/85">
                  <span class="mt-0.5 text-gold-400">✓</span> {f}
                </li>
              ))}
            </ul>
            <a
              href={contact.bookingUrl}
              target="_blank"
              rel="noopener noreferrer"
              class={`mt-8 block rounded-full px-6 py-3 text-center text-sm font-semibold transition-transform duration-300 hover:scale-105 ${
                t.highlighted
                  ? "bg-gradient-to-r from-gold-500 to-coral-500 text-ink"
                  : "border border-ink-border text-cream"
              }`}
            >
              {t.cta}
            </a>
          </Reveal>
        ))
      }
    </div>

    <Reveal client:visible delay={0.3} className="mt-12 text-center">
      <p class="text-sm font-medium text-gold-300">
        <span aria-hidden="true">✓</span> {guarantee}
      </p>
    </Reveal>
  </div>
</section>
